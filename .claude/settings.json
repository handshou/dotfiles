{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs permission to continue\" with title \"Claude Code\" sound name \"Glass\"'",
            "statusMessage": "Sending macOS notification..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "claude-annotator-plugin": {
      "source": {
        "source": "github",
        "repo": "nguyenvanduocit/claude-annotator-plugin"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "agentPushNotifEnabled": true
}
