# =============================================================================
# OPTIONAL BREWFILE - Nice-to-have apps
# =============================================================================
# Install with: brew bundle --file=Brewfile.optional
# =============================================================================

# Taps (if not already added)
tap "asmvik/formulae"

# -----------------------------------------------------------------------------
# CLI: Language version managers
# -----------------------------------------------------------------------------
brew "rustup"
brew "goenv"

# -----------------------------------------------------------------------------
# GUI: Photography & image editing
# -----------------------------------------------------------------------------
cask "rawtherapee"
cask "gimp"

# -----------------------------------------------------------------------------
# GUI: Media tools
# -----------------------------------------------------------------------------
cask "subler"
cask "transmission"

# -----------------------------------------------------------------------------
# GUI: Games & game development
# -----------------------------------------------------------------------------
cask "love"

# -----------------------------------------------------------------------------
# GUI: Automation
# -----------------------------------------------------------------------------
cask "hazel"
