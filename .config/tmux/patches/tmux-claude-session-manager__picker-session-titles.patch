diff --git a/scripts/picker.sh b/scripts/picker.sh
index 7bfdbc1..3a09dda 100755
--- a/scripts/picker.sh
+++ b/scripts/picker.sh
@@ -11,13 +11,41 @@ DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
 
 prefix="$(get_tmux_option @claude_session_prefix 'claude-')"
 
+# Shared status-bar window labeller — returns "[PR#]" for a branch with an open
+# GitHub PR, otherwise "[m]"/folder-name/empty. We treat a numeric "[123]" as a
+# PR and fall back to the tmux window name for everything else.
+WINDOW_TITLE_SH="$(get_tmux_option @claude_window_title_script "$HOME/.config/tmux/window-title.sh")"
+
+# session_title <pane-path> <origin-window-id>
+# Title shown in the picker's left column:
+#   - "<repo> [PR#]" when the branch has an open PR (e.g. "se-mono [568]")
+#   - the origin tmux window name otherwise (falling back to the folder name)
+session_title() {
+  local path="$1" origin="$2" pr repo wname
+  pr=$("$WINDOW_TITLE_SH" "$path" 2>/dev/null)
+  if [[ "$pr" =~ ^\[[0-9]+\]$ ]]; then
+    repo=$(cd "$path" 2>/dev/null && {
+      c=$(git rev-parse --git-common-dir 2>/dev/null) || exit
+      [[ "$c" != /* ]] && c="$PWD/$c"
+      basename "$(dirname "$c")"
+    })
+    if [ -n "$repo" ]; then printf '%s %s' "$repo" "$pr"; else printf '%s' "$pr"; fi
+  else
+    wname=""
+    [ -n "$origin" ] && wname=$(tmux display-message -p -t "$origin" '#{window_name}' 2>/dev/null)
+    [ -z "$wname" ] && wname=$(basename "$path")
+    printf '%s' "$wname"
+  fi
+}
+
 emit_rows() {
-  local now s state at path icon rank ago
+  local now s state at path origin icon rank ago title
   now=$(date +%s)
   tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${prefix}" | while IFS= read -r s; do
     state=$(tmux show-options -qv -t "$s" @claude_state 2>/dev/null)
     at=$(tmux show-options -qv -t "$s" @claude_state_at 2>/dev/null)
     path=$(tmux display-message -p -t "$s" '#{pane_current_path}' 2>/dev/null)
+    origin=$(tmux show-options -qv -t "$s" @claude_origin 2>/dev/null)
     case "$state" in
       waiting) icon=$'\033[33m●\033[0m waiting' rank=0 ;; # yellow - needs input
       idle)    icon=$'\033[32m●\033[0m idle   ' rank=1 ;; # green  - done, your turn
@@ -25,8 +53,11 @@ emit_rows() {
       *)       icon=$'\033[90m●\033[0m   ?    ' rank=2 ;; # grey   - unknown (no hook yet)
     esac
     if [ -n "$at" ]; then ago="$(( (now - at) / 60 ))m"; else ago='-'; fi
-    # rank \t session \t icon \t path \t age   (rank/session hidden via --with-nth)
-    printf '%s\t%s\t%s\t%s\t%s\n' "$rank" "$s" "$icon" "${path/#$HOME/~}" "$ago"
+    title=$(session_title "$path" "$origin")
+    # rank \t session \t icon \t title \t age   (rank/session hidden via --with-nth)
+    # Each session is keyed by a hash of its path, so titles are unique — no
+    # collision handling needed.
+    printf '%s\t%s\t%s\t%s\t%s\n' "$rank" "$s" "$icon" "$title" "$ago"
   done | sort -n # attention-needed (waiting, idle) float to the top
 }
 
