# load scripting additions
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# default layout (can be bsp, stack or float)
yabai -m config layout bsp

# new window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child

# padding set to 12px
yabai -m config top_padding 8
yabai -m config bottom_padding 8
yabai -m config left_padding 8
yabai -m config right_padding 8
yabai -m config window_gap 8

# -- mouse settings --

# center mouse on window with focus
# kept off: with AppleSpacesSwitchOnActivate=true, yanking the cursor to an
# off-space window would trigger macOS to snap back to that space.
yabai -m config mouse_follows_focus off

# modifier for clicking and dragging with mouse
yabai -m config mouse_modifier alt
# set modifier + left-click drag to move window
yabai -m config mouse_action1 move
# set modifier + right-click drag to resize window
yabai -m config mouse_action2 resize

# when window is dropped in center of another window, swap them (on edges it will split it)
yabai -m config mouse_drop_action swap

# disable specific apps
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Effortless$" manage=off
yabai -m rule --add app="^Magnet$" manage=off
yabai -m rule --add app="^Hazel$" manage=off
yabai -m rule --add app="^1Password$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Transmission$" manage=off
yabai -m rule --add app="^Stats$" manage=off
yabai -m rule --add app="^TV$" manage=off

# move apps to specific spaces
# adding ^ before spaces will auto focus on start

# Space 1 gets 20% x-axis padding (dynamic), no vertical padding
yabai -m rule --add app="^Alacritty$" space=1
WIDTH=$(yabai -m query --displays --display | jq '.frame.w')
PADDING=$(echo "$WIDTH * 0.130 / 1" | bc)
yabai -m config --space 1 top_padding 0
yabai -m config --space 1 bottom_padding 0
yabai -m config --space 1 left_padding $PADDING
yabai -m config --space 1 right_padding $PADDING
yabai -m rule --add app="^cmux$" space=1
