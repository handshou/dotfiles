# =============================================================================
# WORK BREWFILE - Work-related tools and apps
# =============================================================================
# Install with: brew bundle --file=Brewfile.work
# =============================================================================

# Taps
tap "supabase/tap"

# -----------------------------------------------------------------------------
# CLI: Containers
# -----------------------------------------------------------------------------
brew "docker"
brew "docker-compose"

# -----------------------------------------------------------------------------
# CLI: Database
# -----------------------------------------------------------------------------
brew "supabase"

# -----------------------------------------------------------------------------
# CLI: Cloud & infrastructure
# -----------------------------------------------------------------------------
brew "pulumi"

# -----------------------------------------------------------------------------
# GUI: Cloud tools
# -----------------------------------------------------------------------------
cask "google-cloud-sdk"

# -----------------------------------------------------------------------------
# GUI: Editors
# -----------------------------------------------------------------------------
cask "visual-studio-code"

# -----------------------------------------------------------------------------
# GUI: Communication (work)
# -----------------------------------------------------------------------------
cask "slack"

# -----------------------------------------------------------------------------
# GUI: Microsoft Office
# -----------------------------------------------------------------------------
cask "microsoft-word"
cask "microsoft-powerpoint"
cask "microsoft-excel"

# -----------------------------------------------------------------------------
# GUI: API tools
# -----------------------------------------------------------------------------
cask "postman"

# -----------------------------------------------------------------------------
# App Store: Project management
# -----------------------------------------------------------------------------
mas "trello", id: 1278508951
